{
  "name": "human-capital-analytics-workspace",
  "version": "1.0.0",
  "description": "Full-stack Human Capital Analytics platform workspace configuration",
  "scripts": {
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend --include=dev",
    "install-all": "npm run install:backend && npm run install:frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run install:frontend && npm run build:frontend",
    "start": "node backend/src/server.js",
    "seed": "node backend/src/utils/seeder.js",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "zod": "^4.4.3"
  }
}